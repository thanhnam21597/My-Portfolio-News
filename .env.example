############################################
# Django / Backend environment variables
# Copy this file to .env for local development
# On Render/Railway, set these in dashboard env vars
############################################

# Django core
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com,.up.railway.app
DJANGO_TIME_ZONE=Asia/Ho_Chi_Minh

# Database
# Local SQLite fallback works when DATABASE_URL is empty.
# Production (Render/Railway Postgres) should provide DATABASE_URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME

# CORS / CSRF (comma-separated, no spaces)
# Add your frontend domains here (Render static, Netlify, Vercel, custom domain, etc.)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend-domain.com
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend-domain.com

# Security (used when DJANGO_DEBUG=False)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

############################################
# Frontend (React) environment variables
# Put this in frontend env (.env) or hosting dashboard
############################################
REACT_APP_API_URL=https://your-backend-domain.com/api
